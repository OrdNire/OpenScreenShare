<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/surfacePreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <LinearLayout
        android:id="@+id/overlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/streaming_overlay"
        android:padding="16dp"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/tvStatusTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_waiting"
            android:textSize="14sp"
            android:textColor="@color/status_text"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatsInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#cccccc"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:text="@string/stop_sharing"
        android:backgroundTint="@color/stop_button"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_stop"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</FrameLayout>
